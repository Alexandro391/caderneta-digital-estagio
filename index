<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Caderneta FMC">
<meta name="theme-color" content="#1E5128">
<title>Caderneta FMC</title>
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="1000281242.png">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%;overflow:hidden}
  body{
    font-family:'Sora',sans-serif;
    background:linear-gradient(160deg,#0F2D18 0%,#1E5128 45%,#2D5A35 75%,#1A4020 100%);
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    position:relative;
    overflow:hidden;
  }

  /* Padrão de fundo sutil */
  body::before{
    content:'';
    position:absolute;
    inset:0;
    background:
      radial-gradient(circle at 15% 20%, rgba(111,207,122,0.08) 0%, transparent 50%),
      radial-gradient(circle at 85% 80%, rgba(58,125,68,0.12) 0%, transparent 50%);
    pointer-events:none;
  }
  body::after{
    content:'';
    position:absolute;
    inset:0;
    opacity:.025;
    background:radial-gradient(circle, white 1px, transparent 1px) 0 0 / 36px 36px;
    pointer-events:none;
  }

  .wrap{
    position:relative;
    z-index:1;
    width:100%;
    max-width:400px;
    padding:0 24px;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:0;
  }

  /* LOGO */
  .logo-ring{
    width:108px;height:108px;
    border-radius:50%;
    padding:5px;
    background:rgba(255,255,255,.12);
    border:2px solid rgba(255,255,255,.2);
    margin-bottom:22px;
    box-shadow:0 8px 40px rgba(0,0,0,.35);
    animation:fadeDown .5s ease both;
  }
  .logo-ring img{
    width:100%;height:100%;
    border-radius:50%;
    object-fit:cover;
    display:block;
  }
  @keyframes fadeDown{from{opacity:0;transform:translateY(-16px)}to{opacity:1;transform:translateY(0)}}

  /* TEXTOS */
  .inst{
    font-size:11px;font-weight:700;color:rgba(255,255,255,.45);
    letter-spacing:1.5px;text-transform:uppercase;
    margin-bottom:6px;
    animation:fadeUp .5s .1s ease both;
  }
  .titulo{
    font-size:22px;font-weight:800;color:white;
    letter-spacing:-.5px;text-align:center;line-height:1.2;
    margin-bottom:4px;
    animation:fadeUp .5s .15s ease both;
  }
  .subtitulo{
    font-size:13px;color:rgba(255,255,255,.55);
    text-align:center;margin-bottom:6px;
    animation:fadeUp .5s .2s ease both;
  }
  .semestre{
    font-family:'DM Mono',monospace;
    font-size:10.5px;color:rgba(255,255,255,.3);
    margin-bottom:36px;
    animation:fadeUp .5s .25s ease both;
  }
  @keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

  /* CARDS DE ACESSO */
  .cards{
    width:100%;
    display:flex;
    flex-direction:column;
    gap:14px;
    animation:fadeUp .5s .3s ease both;
  }

  .acard{
    width:100%;
    background:rgba(255,255,255,.09);
    border:1.5px solid rgba(255,255,255,.16);
    backdrop-filter:blur(24px);
    -webkit-backdrop-filter:blur(24px);
    border-radius:20px;
    padding:22px 24px;
    display:flex;
    align-items:center;
    gap:18px;
    cursor:pointer;
    text-decoration:none;
    transition:all .22s ease;
    -webkit-tap-highlight-color:transparent;
  }
  .acard:hover,.acard:active{
    background:rgba(255,255,255,.16);
    border-color:rgba(255,255,255,.35);
    transform:translateY(-2px);
    box-shadow:0 12px 40px rgba(0,0,0,.3);
  }
  .acard:active{transform:scale(.97);}

  .acard-icon{
    width:52px;height:52px;
    border-radius:14px;
    display:flex;align-items:center;justify-content:center;
    font-size:26px;
    flex-shrink:0;
  }
  .acard-icon.aluno{background:rgba(29,78,216,.35);border:1px solid rgba(59,130,246,.4)}
  .acard-icon.prec {background:rgba(5,150,105,.35);border:1px solid rgba(52,211,153,.4)}

  .acard-text{flex:1}
  .acard-title{
    font-size:16px;font-weight:800;color:white;
    letter-spacing:-.3px;margin-bottom:2px;
  }
  .acard-sub{font-size:12px;color:rgba(255,255,255,.5);line-height:1.4}

  .acard-arrow{
    font-size:18px;color:rgba(255,255,255,.3);
    flex-shrink:0;transition:transform .2s;
  }
  .acard:hover .acard-arrow{transform:translateX(4px);color:rgba(255,255,255,.6)}

  /* RODAPÉ */
  .footer{
    margin-top:32px;
    font-size:10.5px;
    color:rgba(255,255,255,.22);
    text-align:center;
    line-height:1.6;
    animation:fadeUp .5s .4s ease both;
  }

  /* INSTALL BANNER (Android) */
  #install-banner{
    position:fixed;bottom:0;left:0;right:0;
    background:#1E5128;
    border-top:1px solid rgba(255,255,255,.15);
    padding:14px 20px;
    display:none;
    align-items:center;
    gap:12px;
    z-index:100;
    animation:slideUp .35s ease;
  }
  @keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
  #install-banner img{width:36px;height:36px;border-radius:10px}
  #install-banner .ib-text{flex:1}
  #install-banner .ib-title{font-size:13px;font-weight:700;color:white}
  #install-banner .ib-sub{font-size:11px;color:rgba(255,255,255,.55)}
  #install-banner button{
    background:white;color:#1E5128;
    border:none;border-radius:99px;
    padding:8px 18px;font-family:'Sora',sans-serif;
    font-size:12px;font-weight:800;cursor:pointer;
    flex-shrink:0;
  }
  #install-banner .ib-close{
    background:none;color:rgba(255,255,255,.4);
    font-size:18px;padding:4px 8px;min-width:auto;
  }

  /* iOS install hint */
  #ios-hint{
    position:fixed;bottom:16px;left:50%;transform:translateX(-50%);
    background:rgba(15,45,24,.95);border:1px solid rgba(255,255,255,.2);
    backdrop-filter:blur(20px);
    border-radius:16px;padding:16px 20px;
    max-width:320px;width:calc(100% - 32px);
    text-align:center;
    display:none;z-index:100;
    animation:fadeUp .35s ease;
  }
  #ios-hint p{font-size:13px;color:rgba(255,255,255,.8);line-height:1.5}
  #ios-hint strong{color:white}
  #ios-hint .hint-close{
    margin-top:12px;background:rgba(255,255,255,.12);border:none;
    color:white;border-radius:99px;padding:8px 20px;
    font-family:'Sora',sans-serif;font-size:12px;font-weight:700;cursor:pointer;
  }
  /* seta apontando para baixo */
  #ios-hint::after{
    content:'▼';position:absolute;bottom:-18px;left:50%;
    transform:translateX(-50%);font-size:14px;
    color:rgba(255,255,255,.3);
  }
</style>
</head>
<body>

<div class="wrap">

  <div class="logo-ring">
    <img src="1000281242.png" alt="Logo FMC">
  </div>

  <div class="inst">Faculdade de Medicina de Campos</div>
  <div class="titulo">Caderneta Digital<br>de Estágio</div>
  <div class="subtitulo">Estágio Hospitalar · Semestre 2026.1</div>
  <div class="semestre">Sistema Caderneta Digital v1.0</div>

  <div class="cards">
    <a class="acard" href="caderneta-aluno.html">
      <div class="acard-icon aluno">👨‍⚕️</div>
      <div class="acard-text">
        <div class="acard-title">Sou Aluno</div>
        <div class="acard-sub">Registrar presença e acompanhar plantões</div>
      </div>
      <div class="acard-arrow">›</div>
    </a>

    <a class="acard" href="caderneta-preceptor.html">
      <div class="acard-icon prec">🩺</div>
      <div class="acard-text">
        <div class="acard-title">Sou Preceptor</div>
        <div class="acard-sub">Gerar token e confirmar presenças</div>
      </div>
      <div class="acard-arrow">›</div>
    </a>
  </div>

  <div class="footer">
    Mantida pela Fundação Benedito Pereira Nunes<br>
    Campos dos Goytacazes · RJ
  </div>
</div>

<!-- Banner instalação Android -->
<div id="install-banner">
  <img src="1000281242.png" alt="FMC">
  <div class="ib-text">
    <div class="ib-title">Adicionar à tela inicial</div>
    <div class="ib-sub">Acesse como um app, sem precisar de navegador</div>
  </div>
  <button onclick="instalarPWA()">Instalar</button>
  <button class="ib-close" onclick="fecharBanner()">✕</button>
</div>

<!-- Dica instalação iOS -->
<div id="ios-hint">
  <p>Para adicionar à tela inicial:<br>
  Toque em <strong>Compartilhar</strong> (□↑) na barra do Safari<br>
  e depois em <strong>"Adicionar à Tela de Início"</strong></p>
  <button class="hint-close" onclick="document.getElementById('ios-hint').style.display='none'">Entendi</button>
</div>

<script>
  // Service Worker
  if('serviceWorker' in navigator){
    navigator.serviceWorker.register('/sw.js').catch(()=>{});
  }

  // Detectar instalação PWA
  let deferredPrompt = null;

  const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isStandalone = window.matchMedia('(display-mode: standalone)').matches
    || window.navigator.standalone === true;

  if(!isStandalone){
    if(isIOS){
      // Mostrar dica iOS após 2.5s
      setTimeout(()=>{
        document.getElementById('ios-hint').style.display='block';
      }, 2500);
    } else {
      // Android — escutar evento beforeinstallprompt
      window.addEventListener('beforeinstallprompt', e => {
        e.preventDefault();
        deferredPrompt = e;
        setTimeout(()=>{
          document.getElementById('install-banner').style.display='flex';
        }, 1500);
      });
    }
  }

  function instalarPWA(){
    if(!deferredPrompt) return;
    deferredPrompt.prompt();
    deferredPrompt.userChoice.then(()=>{
      deferredPrompt=null;
      fecharBanner();
    });
  }

  function fecharBanner(){
    document.getElementById('install-banner').style.display='none';
  }
</script>
</body>
</html>
