<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Painel Preceptor · FMC</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;800&display=swap" rel="stylesheet">
<style>
:root {
  --fmc-vd: #1E5128; --fmc-v: #3A7D44; --g100: #F1F5F9; --g900: #0F172A;
}
body { font-family: 'Sora', sans-serif; background: var(--g100); margin: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
.card { background: white; padding: 40px; border-radius: 24px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); text-align: center; max-width: 350px; width: 90%; }
h1 { color: var(--fmc-vd); font-size: 18px; margin-bottom: 5px; }
p { color: #64748B; font-size: 13px; margin-bottom: 30px; }
.token-box { background: var(--g100); padding: 20px; border-radius: 16px; border: 2px dashed #CBD5E1; margin-bottom: 20px; }
.token-label { font-size: 11px; font-weight: 800; color: #94A3B8; letter-spacing: 1px; margin-bottom: 10px; display: block; }
.token-value { font-size: 42px; font-weight: 800; color: var(--fmc-v); letter-spacing: 2px; }
.info-data { font-size: 12px; font-weight: 600; color: var(--g900); margin-top: 10px; opacity: 0.6; }
.btn-refresh { background: var(--fmc-vd); color: white; border: none; padding: 12px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; width: 100%; font-family: 'Sora'; }
</style>
</head>
<body>

<div class="card">
  <h1>Validação de Estágio</h1>
  <p>Informe o código abaixo aos alunos presentes no plantão.</p>
  
  <div class="token-box">
    <span class="token-label">TOKEN DO DIA</span>
    <div class="token-value" id="token-display">--</div>
    <div class="info-data" id="data-display">--/--/----</div>
  </div>

  <button class="btn-refresh" onclick="gerarToken()">Atualizar Código</button>
</div>

<script>
function gerarToken() {
  const hoje = new Date();
  const dia = hoje.getDate();
  // Lógica: Dia do mês multiplicado por 14 (Ex: dia 03 * 14 = 42)
  const token = dia * 14; 
  
  document.getElementById('token-display').innerText = token;
  document.getElementById('data-display').innerText = hoje.toLocaleDateString('pt-BR');
}

// Gera ao abrir a página
gerarToken();
</script>

</body>
</html>
